#!/bin/bash
UPPER_VOL_LIMIT=100
LOWER_VOL_LIMIT=0

SINK=$(pactl list short | grep RUNNING)
# There might not be a running sink
if [[ $SINK == "" ]]; then
  SINK=$(pactl list short | grep SUSPENDED | head -n1)
fi

SINK_NUM=$(echo $SINK | awk -F' ' '{print $1}')

if [[ $1 == "m" ]]; then
  pactl set-sink-mute $SINK_NUM toggle
else

  # Check if adjusting volume, or setting volume
  if [[ $(echo $1 | grep -Eo "(\+|-)") == "" ]]; then
    TARGET=$(echo $1 | grep -Eo "[0-9]{1,3}")
  else
    PCT_ADJ=$(echo $1 | grep -Eo "(\+|-)[0-9]{1,2}")
    CUR_VOL=$(pactl list sinks | grep '^[[:space:]]Volume:' | tail -n1 | awk -F'/ ' '{print $2}' | grep -oE "[0-9]{1,3}")
    TARGET=$(($CUR_VOL $PCT_ADJ))
  fi

  # Check target volume is in bounds
  if [[ $TARGET -le $UPPER_VOL_LIMIT && $TARGET -ge $LOWER_VOL_LIMIT ]]; then
    pactl set-sink-volume $SINK_NUM $1
  elif (( $TARGET > $UPPER_VOL_LIMIT )); then
    echo "LIMITING AT 100"
    pactl set-sink-volume $SINK_NUM "$UPPER_VOL_LIMIT%"
  else
    echo "LIMITING AT 0"
    pactl set-sink-volume $SINK_NUM "$LOWER_VOL_LIMIT%"
  fi

fi
