#!/bin/bash
if [ $EUID -ne 0 ]; then
  echo "Please run as root"
  exit
fi
if grep -q "on" /etc/prime-discrete; then
  prime-select intel
  sed -ie 's/output DP-1-3/output DP-3/g' $HOME/.config/i3/config
  sed -ie 's/output eDP-1-1/output eDP-1/g' $HOME/.config/i3/config
else
  prime-select nvidia
  sed -ie 's/output DP-3/output DP-1-3/g' $HOME/.config/i3/config
  sed -ie 's/output eDP-1/output eDP-1-1/g' $HOME/.config/i3/config
fi
